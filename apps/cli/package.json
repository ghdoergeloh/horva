{
  "name": "@timetracker/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "tt": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "node build.mjs --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "pack": "node build.mjs && cd dist && pnpm pack --pack-destination ..",
    "typecheck": "tsc"
  },
  "prettier": "@timetracker/prettier-config",
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "@timetracker/core": "workspace:*",
    "@timetracker/db": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "dotenv": "catalog:",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@timetracker/eslint-config": "workspace:*",
    "@timetracker/prettier-config": "workspace:*",
    "@timetracker/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "^8.16.0",
    "esbuild": "^0.25.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
