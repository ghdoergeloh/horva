{
  "extends": "@horva/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": [],
    "paths": {
      "~/*": ["./src/renderer/src/*"]
    },
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "out"
  },
  "include": ["src/renderer/**/*", "src/renderer/**/*.json"]
}
