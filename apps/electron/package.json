    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "catalog:",
    "lucide-react": "catalog:",
    "prettier": "catalog:",
