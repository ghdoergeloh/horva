{
  "name": "@horva/electron-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "clean": "git clean -xdf .cache .turbo out node_modules",
    "dev": "electron-vite dev",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint .",
    "pack": "electron-vite build && electron-builder",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false -p tsconfig.node.json && tsc --noEmit --emitDeclarationOnly false -p tsconfig.web.json"
