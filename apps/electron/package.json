    "pg": "catalog:",
    "react-i18next": "catalog:",
    "rrule": "catalog:"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@horva/contract": "workspace:*",
