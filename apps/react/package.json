{
  "name": "@horva/react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "vite",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "prettier": "@horva/prettier-config",
  "dependencies": {
    "@horva/auth": "workspace:*",
    "@horva/contract": "workspace:*",
    "@horva/ui": "workspace:*",
    "@orpc/client": "^1.13.5",
    "@orpc/react-query": "^1.13.5",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.160.0",
    "@tanstack/react-router-devtools": "^1.160.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "devDependencies": {
    "@horva/eslint-config": "workspace:*",
    "@horva/prettier-config": "workspace:*",
    "@horva/tailwind-config": "workspace:*",
    "@horva/tsconfig": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/router-plugin": "^1.160.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
