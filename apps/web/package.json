{
  "name": "@horva/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "vite",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "prettier": "@horva/prettier-config",
  "dependencies": {
    "@dnd-kit/core": "catalog:",
    "@dnd-kit/sortable": "catalog:",
    "@dnd-kit/utilities": "catalog:",
    "@horva/auth": "workspace:*",
    "@horva/contract": "workspace:*",
    "@horva/ui": "workspace:*",
    "@orpc/client": "catalog:",
    "@orpc/contract": "catalog:",
    "@orpc/tanstack-query": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "i18next": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-i18next": "catalog:",
    "rrule": "catalog:"
  },
  "devDependencies": {
    "@horva/eslint-config": "workspace:*",
    "@horva/prettier-config": "workspace:*",
    "@horva/tailwind-config": "workspace:*",
    "@horva/tsconfig": "workspace:*",
    "@internationalized/date": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "lucide-react": "catalog:",
    "prettier": "catalog:",
    "react-aria-components": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
