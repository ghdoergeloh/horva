# Database (compose.yml reads POSTGRES_* on `docker compose up`;
# application code only reads DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=horva
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/horva

# Better Auth (required when using @horva/auth)
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# SMTP — Mailpit for development
# compose.yml exposes the SMTP listener on ${MAILPIT_PORT:-1025} and the
# inbox web UI on ${MAILPIT_WEB_PORT:-8025}. Override those here if the
# defaults clash with something else on your machine.
MAILPIT_PORT=1025
MAILPIT_WEB_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=noreply@localhost

# API
API_PORT=3000

# Frontend
VITE_API_URL=http://localhost:3000

# OpenTelemetry (structured logging / wide events)
# Leave OTEL_EXPORTER_OTLP_ENDPOINT unset in development — logs will be
# pretty-printed as JSON to stdout instead.
# In production, point this at your OTLP-compatible backend:
#   Honeycomb:  https://api.honeycomb.io
#   Grafana:    https://<stack>.grafana.net/otlp
#   Datadog:    https://otlp.datadoghq.com
OTEL_SERVICE_NAME=api
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-api-key
